//crear un programa que calcule el descuento de un 25% de un salario devengado, capture su nombre y  su salario.}
  ESCRIBIR "PROGRAMA QUE TE DESCUENTA EL 25%"
  ESCRIBIR "DIGITE SU NOMBRE"
  LEER NOMBRE
  ESCRIBIR " DIGITE SU SALARIO "
  LEER SALARIO
  PORCENTAJE = SALARIO * 25 /100 // ESTA LINEA CALCULA EL PORCENTAJE 
  SALARIOTOTAL = SALARIO - PORCENTAJE
  ESCRIBIR " "
  ESCRIBIR " SU NOMBRE ES ",NOMBRE," SU SALARIO DE VENGADO ES ",SALARIO,"Y EL DESCUENTO DEL 25%, SU SALARIO QUEDA EN ",SALARIOTOTAL

FINPROCESO
